# ── docker compose ──────────────────────────────────────────────
# ocr-cpu는 프로필 없는 기본 서비스 — `docker compose up`만으로 기동 (.env 불필요)
# CUDA는 서비스명 지정으로 cuda 프로필이 자동 활성화: docker compose up -d --build ocr-cuda
# 신규 엔진 (RTX 5070 Ti 단일 GPU — 한 시점에 GPU 스택 하나만!):
#   OvisOCR2:     docker compose --profile ovis up -d --build ovisocr2 ocr-ovis    → :8002
#   PaddleOCR-VL: docker compose --profile paddle up -d --build paddleocr-vl ocr-paddle → :8003

# ── 애플리케이션 (docker-compose.yml의 environment로 전달됨) ────
# OCR_DEVICE=cpu            # cpu | cuda | metal(macOS 로컬 전용 — Docker 불가, README 참조)
# OCR_DTYPE=auto            # auto | bfloat16 | float16 | float32
# OCR_ENGINE=unlimited      # unlimited | fake(모델 없이 데모) | ovisocr2 | paddleocr_vl
#                           # ovisocr2/paddleocr_vl은 OCR_SIDECAR_URL 필수 — compose
#                           # 프로필(ovis/paddle)이 자동으로 설정한다
# OCR_MOE_FAST=1            # MoE 디코드 패스트패스 강제 (기본: Metal에서만 on)
# OCR_MOE_FUSED=0           # CUDA MoE 융합 디코드 끄기 (기본: CUDA에서 on)
# OCR_CUDA_GRAPHS=0         # CUDA Graph 디코드 끄기 (기본: CUDA에서 on — 실측 8p 191s→57s·sm 98%)
# MODEL_ID=baidu/Unlimited-OCR
# PAGES_PER_CHUNK=8
# RENDER_DPI=200
# MAX_UPLOAD_MB=100
# MAX_PAGES=200
# MAX_PAGE_OUTPUT_CHARS=16384  # 페이지별 decoded 출력 hard limit (0 이하=비활성)
# MAX_PAGE_OUTPUT_TOKENS=6144  # 페이지별 생성 토큰 hard limit (0 이하=비활성)
# JOB_TTL_DAYS=0            # 터미널 잡(done/error/canceled) 자동 삭제 보존 일수 — 0=비활성(기본, opt-in)
#                           # N>0이면 시작 시 1회 + 6시간마다 GC. 실행 중·번역 중 잡은 삭제되지 않음
# HF_TOKEN=                 # 프라이빗 미러 사용 시에만 필요 (runtime env로만 전달 — 빌드 레이어 미포함)
# ALLOWED_HOSTS=localhost,127.0.0.1   # Host 헤더 화이트리스트(콤마 구분, DNS rebinding 방어)
#                                     # LAN/도메인 공개 시 서버 IP·호스트명 추가 — README §보안.
#                                     # compose가 컨테이너로 전달함 (빈 값이면 서버 기본값)

# ── RTX 5070 Ti / GPU 공통 ─────────────────────────────────────
# GPU_DEVICE=0              # CUDA_VISIBLE_DEVICES로 전달 — 두 번째 GPU는 1

# ── sidecar 엔진 공용 클라이언트 (OCR_ENGINE=ovisocr2|paddleocr_vl) ──
# compose 프로필이 OCR_SIDECAR_URL을 자동 설정한다. 로컬(uv) 실행 시에만 직접 지정.
# OCR_SIDECAR_URL=                    # 예: http://127.0.0.1:8080
# OCR_SIDECAR_CONNECT_TIMEOUT_S=10    # 연결 타임아웃(초)
# OCR_SIDECAR_READ_TIMEOUT_S=600     # 페이지 1장 추론 대기 상한(초)
# OCR_SIDECAR_HEALTH_TIMEOUT_S=5     # health 응답 대기(초)
# OCR_SIDECAR_MAX_RESPONSE_MB=20     # 응답 크기 상한 (response bomb 방어)
# OCR_SIDECAR_RETRIES=1              # 연결 수립 실패 재시도 횟수
# OCR_REMOTE_PAGE_CONCURRENCY=1      # sidecar 페이지 동시 요청 수 — 기본 1 권장.
#     >1은 페이지 순서를 그대로 보존하지만(실측: c1·c4 출력 바이트 동일) 속도
#     이득은 없다 — sidecar가 추론을 내부에서 직렬화하기 때문이다(단일 GPU 정책).

# ── OvisOCR2 sidecar (--profile ovis) ──────────────────────────
# OVIS_MODEL_ID=ATH-MaaS/OvisOCR2
# OVIS_MODEL_REVISION=      # 빈 값 = 코드에 고정된 검증 SHA(65c619d3…) 사용
# OVIS_DTYPE=bfloat16
# OVIS_GPU_MEMORY_UTILIZATION=0.80   # 16GB에서 디스플레이/런타임 몫을 남긴 보수값 (0.92 초과 거부)
# OVIS_MAX_MODEL_LEN=24576  # 비전 토큰(~8K@2880²) + 출력(8192) 여유 — OOM 시 줄일 수 있음
# OVIS_MAX_OUTPUT_TOKENS=8192        # 페이지별 생성 토큰 상한
# OVIS_MAX_NUM_SEQS=1       # 동시 시퀀스 1 — 단일 GPU 예측 가능성 우선
# OVIS_MIN_PIXELS=          # 빈 값 = 공식 기본 448*448
# OVIS_MAX_PIXELS=          # 빈 값 = 공식 기본 2880*2880 — OOM 완화 1순위로 낮추는 값
# OVIS_GDN_PREFILL_BACKEND=triton    # sm_120(컨슈머 Blackwell)은 triton 필수 — 모델 카드 예제와 동일

# ── PaddleOCR-VL-1.6 sidecar (--profile paddle) ────────────────
# PADDLEOCR_MODEL_ID=PaddlePaddle/PaddleOCR-VL-1.6
# PADDLEOCR_MODEL_REVISION= # 빈 값 = 코드에 고정된 검증 SHA(66317acc…) 사용
# PADDLEOCR_DEVICE=gpu:0    # gpu:N | cpu (파이프라인 전체 디바이스 — 컴포넌트별 분리는 미지원)
# PADDLEOCR_MIN_PIXELS=     # 빈 값 = 파이프라인 기본값
# PADDLEOCR_MAX_PIXELS=     # 빈 값 = 파이프라인 기본값 — OOM 완화 1순위로 낮추는 값

# ── 한국어 번역 — OpenAI 호환 API (Chat Completions·Responses 둘 다 지원) ──
# 주의: 실 API 키는 .env에만 적는다 (.env는 git에 커밋되지 않음)
# base URL은 버전 경로까지 포함 (예: https://api.openai.com/v1,
# http://localhost:1234/v1, http://localhost:11434/v1)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# 선택 — 번역 세부 설정 (기본값이면 생략 가능)
# TRANSLATE_MODEL=                       # 미설정 시 OPENAI_MODEL 사용
# TRANSLATE_API_MODE=auto                # auto|chat|responses (auto: responses 시도 → 미지원 시 chat 폴백)
# TRANSLATE_CONCURRENCY=4                # 동시 번역 요청 수
# TRANSLATE_TIMEOUT_S=180                # 요청 타임아웃(초)
# TRANSLATE_MAX_RETRIES=3                # 429/5xx 재시도 횟수
# TRANSLATE_TEMPERATURE=0                # "none"이면 temperature 파라미터 자체를 생략
# TRANSLATE_MAX_TOKENS_PARAM=max_tokens  # max_tokens|max_completion_tokens|none
# TRANSLATE_REASONING=off                # reasoning 모델용: off|low|medium|high|xhigh (빈 값=파라미터 미전송)
#                                        # reasoning 모델(OpenRouter 등)은 off 권장 — 실측 22배 빠르고 비용 ~1/40
#                                        # effort별 요청 max_tokens: off/미설정 8192 · low 10240 · medium 20480 · high 40960 · xhigh 81920
#                                        # 출력이 잘리면(finish_reason=length / incomplete) 예산 2배로 자동 1회 재시도
