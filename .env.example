# ── docker compose ──────────────────────────────────────────────
# 기본 프로필: cpu | cuda
COMPOSE_PROFILES=cpu

# ── 애플리케이션 (docker-compose.yml의 environment로 전달됨) ────
# OCR_DEVICE=cpu            # cpu | cuda | metal(macOS 로컬 전용 — Docker 불가, README 참조)
# OCR_DTYPE=auto            # auto | bfloat16 | float16 | float32
# OCR_ENGINE=unlimited      # unlimited | fake (모델 없이 데모)
# MODEL_ID=baidu/Unlimited-OCR
# PAGES_PER_CHUNK=8
# RENDER_DPI=200
# MAX_UPLOAD_MB=100
# MAX_PAGES=200
# HF_TOKEN=                 # 프라이빗 미러 사용 시에만 필요
